{% if service.services %}
<section class="services">

    {% if service.services.heading %}
    <h2 class="pipe pt-5">{{ service.services.heading }}</h2>
    {% endif %}

    {% if service.services.intro %}
    <p class="intro-text">{{ service.services.intro }}</p>
    {% endif %}

    {% if service.services.items %}
    <div class="services-list">

        {% for item in service.services.items %}
        <div class="service-item" id="{{ item.anchor }}">

            {% if item.title %}
            <h3>{{ item.title }}</h3>
            {% endif %}

            {# Loop through the paragraphs array for the description #}
            {% if item.paragraphs %}
                {% for paragraph in item.paragraphs %}
                <p class="py-2">{{ paragraph }}</p>
                {% endfor %}
            {% endif %}

            {# Render the service image if it exists #}
            {% if item.image %}
            <div class="service-image my-3">
                <img src="{{ item.image.src }}" alt="{{ item.image.alt }}" loading="lazy" class="img-fluid">
            </div>
            {% endif %}

            {# Optional: Render Popular Features if present #}
            {% if item.features %}
            <div class="service-features mt-4">
                <h4>{{ item.features.heading }}</h4>
                <ul class="ps-3 li">
                    {% for feature in item.features.items %}
                    <li>{{ feature }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}

            {# Optional: Render Benefits if present #}
            {% if item.benefits %}
            <div class="service-benefits mt-4">
                <h4>{{ item.benefits.heading }}</h4>
                <ul class="ps-3 li">
                    {% for benefit in item.benefits.items %}
                    <li>{{ benefit }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}

            {# Loop through the closing paragraphs array #}
            {% if item.closing %}
                {% for closingParagraph in item.closing %}
                <p class="py-2 fst-italic">{{ closingParagraph }}</p>
                {% endfor %}
            {% endif %}

        </div>
        {% endfor %}

    </div>
    {% endif %}

</section>
{% endif %}


