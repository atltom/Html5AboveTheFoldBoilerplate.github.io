    function navDropdownClick(e) {
      // Only intercept click on touch devices / mobile screens (< 600px)
      if (window.innerWidth < 600) {
        var navDropdown = document.getElementById("nav-dropdown");
        
        // If the dropdown isn't open yet on mobile, open it first
        if (navDropdown && !navDropdown.classList.contains("show")) {
          e.preventDefault(); 
          navDropdown.classList.add("show");
        }
        // If it IS already open on mobile, tapping it again will naturally follow the link to /services/
      }
    }

    // Close dropdown when clicking outside
    window.addEventListener('click', function(e) {
      if (!e.target.closest('.dropdown')) {
        var navDropdown = document.getElementById("nav-dropdown");
        if (navDropdown && navDropdown.classList.contains("show")) {
          navDropdown.classList.remove("show");
        }
      }
    });





