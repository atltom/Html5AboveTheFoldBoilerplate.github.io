<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {# =========================     SEO CORE     ========================= #}
  <title>{{ title }}</title>
  <meta name="description" content="{{ description  }}">
  
  {% set rawUrl = canonical or page.url %}
  {% set cleanUrl = rawUrl | replace('index.html', '') | replace('.html', '') | replace('//', '') %}
  <link rel="canonical" href="https://sphaneufassociates.com{{ cleanUrl }}">

  {# =========================     OPEN GRAPH     ========================= #}
  <meta property="og:title" content="{{ title or 'S. Phaneuf & Associates' }}">
  <meta property="og:description" content="{{ description or 'Professional paving and site development services in Massachusetts.' }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://sphaneufassociates.com{{ page.url }}">
  <meta property="og:image" content="https://sphaneufassociates.com/images/{{ ogImage or 'S-Phaneuf-Associates.webp' }}">
  {# =========================     FAVICONS     ========================= #}
  <link rel="icon" href="/images/favicon96c.png" sizes="96x96">
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png">
  {# =========================     CSS     ========================= #}
  <link rel="stylesheet" href="/css/templatestyles.css">
  {{ head | safe }}
  {# ========================= BREADCRUMB LD JSON =========================  #}
  {% include "breadcrumbs-json.njk" %}
</head>
<body class="{{ bodyClass }}">
  {% include "header.njk" %}
  <a class="skip-link" href="#main-content">Skip to content</a>
  <main class="{{ mainClass }}">
     {% if heroHeading %}
        {% include "components/hero.njk" %}
    {% endif %}
    {{ content | safe }}
  </main>
  {% include "footer.njk" %}
  {# <!--<script src="/js/main.js" defer></script>--> #}
</body>
</html>